{
  "schema": "tropical_program_1",
  "name": "SinOsc",
  "inputs": [
    { "name": "freq", "type": "freq" }
  ],
  "outputs": [
    { "name": "sine", "type": "float" }
  ],
  "input_defaults": { "freq": 440 },
  "instances": {
    "sin": {
      "program": "Sin",
      "inputs": {
        "x": {
          "op": "mul",
          "args": [
            6.283185307179586,
            { "op": "div", "args": [
              { "op": "mul", "args": [
                { "op": "sample_index" },
                { "op": "input", "name": "freq" }
              ]},
              { "op": "sample_rate" }
            ]}
          ]
        }
      }
    }
  },
  "process": {
    "outputs": {
      "sine": { "op": "nested_out", "ref": "sin", "output": "out" }
    }
  }
}
