{
  "schema": "tropical_program_1",
  "name": "SoftClip",
  "inputs": [
    { "name": "input", "type": "signal" },
    { "name": "drive", "type": "float" }
  ],
  "outputs": [
    { "name": "out", "type": "signal" }
  ],
  "input_defaults": { "input": 0, "drive": 1 },
  "instances": {
    "tanh": {
      "program": "Tanh",
      "inputs": {
        "x": {
          "op": "mul", "args": [
            { "op": "input", "name": "drive" },
            { "op": "input", "name": "input" }
          ]
        }
      }
    }
  },
  "process": {
    "outputs": {
      "out": { "op": "nested_out", "ref": "tanh", "output": "out" }
    }
  }
}
