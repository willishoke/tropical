              ]
            }
          }
        }
      },
      {
        "op": "next_update",
        "target": { "kind": "reg", "name": "state" },
        "expr": {
          "op": "let",
          "bind": {
            "lsb": {
              "op": "bitAnd",
              "args": [{ "op": "reg", "name": "state" }, 1]
            },
            "shifted": {
              "op": "rshift",
              "args": [{ "op": "reg", "name": "state" }, 1]
