                "op": "sub",
                "args": [
                  1,
                  {
                    "op": "div",
                    "args": [
                      {
                        "op": "mul",
                        "args": [2, { "op": "input", "name": "rate" }]
                      },
                      { "op": "sample_rate" }
                    ]
                  }
                ]
              }
            },
            "in": {
              "op": "mul",
              "args": [
                {
                  "op": "gt",
                  "args": [
