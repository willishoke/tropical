{
  "schema": "tropical_program_1",
  "name": "Delay4410",
  "inputs": ["x"],
  "outputs": ["y"],
  "regs": { "buf": { "zeros": 4410 } },
  "input_defaults": { "x": 0 },
  "breaks_cycles": true,
  "process": {
    "outputs": {
      "y": { "op": "index", "args": [{ "op": "reg", "name": "buf" }, { "op": "mod", "args": [{ "op": "sample_index" }, 4410] }] }
    },
    "next_regs": {
      "buf": { "op": "array_set", "args": [{ "op": "reg", "name": "buf" }, { "op": "mod", "args": [{ "op": "sample_index" }, 4410] }, { "op": "input", "name": "x" }] }
    }
  }
}
