```tropical
program BlepSaw(freq: freq = 440 in [0, null]) -> (saw: signal) {
  reg phase = 0
  saw = let { inc: freq / sampleRate(); pw: phase; raw: 2 * pw - 1; tp: pw / inc; tpr: (pw - 1) / inc; bpost: select(pw < inc, 2 * tp - tp * tp - 1, 0); bpre: select(pw > 1 - inc, tpr * tpr + 2 * tpr + 1, 0) } in raw - bpost - bpre
  next phase = (phase + freq / sampleRate()) % 1
}
```
