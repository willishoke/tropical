```tropical
program Sin(x: float = 0) -> (out: float) {
  out = let { n: round(x * 0.3183098861837907); r: x - n * 3.141592653589793; odd_n: n & 1; sign: 1 - 2 * odd_n; r2: r * r; poly: fold([-2.505210838544172e-8, 0.0000027557319223985893, -0.0001984126984126984, 0.008333333333333333, -0.16666666666666666, 1], 0, (a, c) => c + a * r2) } in sign * (r * poly)
}
```
