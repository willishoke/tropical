{
  "schema": "tropical_program_1",
  "name": "OnePole",
  "inputs": [
    { "name": "input", "type": "signal" },
    { "name": "g", "type": "float" }
  ],
  "outputs": [
    { "name": "out", "type": "signal" }
  ],
  "regs": { "s": 0 },
  "input_defaults": { "input": 0, "g": 0.1 },
  "instances": {
    "tanh_in": {
      "program": "Tanh",
      "inputs": { "x": { "op": "input", "name": "input" } }
    },
    "tanh_s": {
      "program": "Tanh",
      "inputs": { "x": { "op": "reg", "name": "s" } }
    }
  },
  "process": {
    "outputs": {
      "out": {
        "op": "add", "args": [
          { "op": "reg", "name": "s" },
          { "op": "mul", "args": [
            { "op": "input", "name": "g" },
            { "op": "sub", "args": [
              { "op": "nested_out", "ref": "tanh_in", "output": "out" },
              { "op": "nested_out", "ref": "tanh_s", "output": "out" }
            ]}
          ]}
        ]
      }
    },
    "next_regs": {
      "s": {
        "op": "add", "args": [
          { "op": "reg", "name": "s" },
          { "op": "mul", "args": [
            { "op": "input", "name": "g" },
            { "op": "sub", "args": [
              { "op": "nested_out", "ref": "tanh_in", "output": "out" },
              { "op": "nested_out", "ref": "tanh_s", "output": "out" }
            ]}
          ]}
        ]
      }
    }
  }
}
