{
  "schema": "tropical_program_1",
  "name": "Pow",
  "inputs": [
    { "name": "x", "type": "float" },
    { "name": "y", "type": "float" }
  ],
  "outputs": [
    { "name": "out", "type": "float" }
  ],
  "input_defaults": { "x": 1, "y": 1 },
  "instances": {
    "log_x": {
      "program": "Log",
      "inputs": { "x": { "op": "input", "name": "x" } }
    },
    "exp": {
      "program": "Exp",
      "inputs": {
        "x": {
          "op": "mul", "args": [
            { "op": "input", "name": "y" },
            { "op": "nested_out", "ref": "log_x", "output": "out" }
          ]
        }
      }
    }
  },
  "process": {
    "outputs": {
      "out": { "op": "nested_out", "ref": "exp", "output": "out" }
    }
  }
}
