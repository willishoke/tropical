{
  "schema": "tropical_program_1",
  "name": "Sin",
  "inputs": [
    { "name": "x", "type": "float" }
  ],
  "outputs": [
    { "name": "out", "type": "float" }
  ],
  "input_defaults": { "x": 0 },
  "process": {
    "outputs": {
      "out": {
        "op": "let",
        "bind": {
          "n": { "op": "round", "args": [
            { "op": "mul", "args": [{ "op": "input", "name": "x" }, 0.3183098861837907] }
          ]},
          "r": { "op": "sub", "args": [
            { "op": "input", "name": "x" },
            { "op": "mul", "args": [{ "op": "binding", "name": "n" }, 3.141592653589793] }
          ]},
          "odd_n": { "op": "bit_and", "args": [
            { "op": "binding", "name": "n" }, 1
          ]},
          "sign": { "op": "sub", "args": [
            1,
            { "op": "mul", "args": [2, { "op": "binding", "name": "odd_n" }] }
          ]},
          "r2": { "op": "mul", "args": [
            { "op": "binding", "name": "r" },
            { "op": "binding", "name": "r" }
          ]},
          "poly": {
            "op": "fold",
            "over": [
              -2.505210838544172e-8,
              2.7557319223985893e-6,
              -0.0001984126984126984,
              0.008333333333333333,
              -0.16666666666666666,
              1.0
            ],
            "init": 0,
            "acc_var": "a",
            "elem_var": "c",
            "body": {
              "op": "add", "args": [
                { "op": "binding", "name": "c" },
                { "op": "mul", "args": [
                  { "op": "binding", "name": "a" },
                  { "op": "binding", "name": "r2" }
                ]}
              ]
            }
          }
        },
        "in": {
          "op": "mul", "args": [
            { "op": "binding", "name": "sign" },
            { "op": "mul", "args": [
              { "op": "binding", "name": "r" },
              { "op": "binding", "name": "poly" }
            ]}
          ]
        }
      }
    }
  }
}
