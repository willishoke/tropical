{
  "schema": "tropical_program_1",
  "name": "LadderFilter",
  "inputs": [
    "input",
    { "name": "cutoff", "type": "freq" },
    { "name": "resonance", "type": "unipolar" },
    "drive"
  ],
  "outputs": ["lp", "bp", "hp", "notch"],
  "input_defaults": {
    "input": 0,
    "cutoff": 1000,
    "resonance": 0.5,
    "drive": 1
  },
  "delays": {
    "prev_lp": {
      "update": { "op": "nested_out", "ref": "pole4", "output": "out" },
      "init": 0
    }
  },
  "instances": {
    "tanh_in": {
      "program": "Tanh",
      "inputs": {
        "x": {
          "op": "mul", "args": [
            { "op": "input", "name": "drive" },
            { "op": "input", "name": "input" }
          ]
        }
      }
    },
    "sin_g": {
      "program": "Sin",
      "inputs": {
        "x": {
          "op": "mul", "args": [
            3.141592653589793,
            { "op": "div", "args": [
              { "op": "clamp", "args": [
                { "op": "input", "name": "cutoff" },
                20,
                { "op": "mul", "args": [0.49, { "op": "sample_rate" }] }
              ]},
              { "op": "sample_rate" }
            ]}
          ]
        }
      }
    },
    "pole1": {
      "program": "OnePole",
      "inputs": {
        "input": {
          "op": "sub", "args": [
            { "op": "nested_out", "ref": "tanh_in", "output": "out" },
            { "op": "mul", "args": [
              { "op": "mul", "args": [4, { "op": "input", "name": "resonance" }] },
              { "op": "delay_ref", "id": "prev_lp" }
            ]}
          ]
        },
        "g": {
          "op": "mul", "args": [
            2,
            { "op": "nested_out", "ref": "sin_g", "output": "out" }
          ]
        }
      }
    },
    "pole2": {
      "program": "OnePole",
      "inputs": {
        "input": { "op": "nested_out", "ref": "pole1", "output": "out" },
        "g": {
          "op": "mul", "args": [
            2,
            { "op": "nested_out", "ref": "sin_g", "output": "out" }
          ]
        }
      }
    },
    "pole3": {
      "program": "OnePole",
      "inputs": {
        "input": { "op": "nested_out", "ref": "pole2", "output": "out" },
        "g": {
          "op": "mul", "args": [
            2,
            { "op": "nested_out", "ref": "sin_g", "output": "out" }
          ]
        }
      }
    },
    "pole4": {
      "program": "OnePole",
      "inputs": {
        "input": { "op": "nested_out", "ref": "pole3", "output": "out" },
        "g": {
          "op": "mul", "args": [
            2,
            { "op": "nested_out", "ref": "sin_g", "output": "out" }
          ]
        }
      }
    }
  },
  "process": {
    "outputs": {
      "lp": { "op": "nested_out", "ref": "pole4", "output": "out" },
      "bp": {
        "op": "sub", "args": [
          { "op": "nested_out", "ref": "pole2", "output": "out" },
          { "op": "nested_out", "ref": "pole4", "output": "out" }
        ]
      },
      "hp": {
        "op": "sub", "args": [
          { "op": "input", "name": "input" },
          { "op": "nested_out", "ref": "pole4", "output": "out" }
        ]
      },
      "notch": {
        "op": "add", "args": [
          { "op": "sub", "args": [
            { "op": "input", "name": "input" },
            { "op": "nested_out", "ref": "pole4", "output": "out" }
          ]},
          { "op": "nested_out", "ref": "pole4", "output": "out" }
        ]
      }
    }
  }
}
