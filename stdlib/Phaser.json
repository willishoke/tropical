{
  "schema": "tropical_program_1",
  "name": "Phaser",
  "inputs": ["input", "feedback", "lfo_speed"],
  "outputs": ["output", "lfo"],
  "regs": { "fb": 0 },
  "input_defaults": { "input": 0, "feedback": 0.4, "lfo_speed": 0.2 },
  "programs": {
    "_allpassStage": {
      "schema": "tropical_program_1",
      "name": "_allpassStage",
      "inputs": ["x", "a"],
      "outputs": ["y"],
      "regs": { "x_prev": 0, "y_prev": 0 },
      "process": {
        "outputs": {
          "y": { "op": "add", "args": [{ "op": "add", "args": [{ "op": "mul", "args": [{ "op": "neg", "args": [{ "op": "input", "name": "a" }] }, { "op": "input", "name": "x" }] }, { "op": "reg", "name": "x_prev" }] }, { "op": "mul", "args": [{ "op": "input", "name": "a" }, { "op": "reg", "name": "y_prev" }] }] }
        },
        "next_regs": {
          "x_prev": { "op": "input", "name": "x" },
          "y_prev": { "op": "add", "args": [{ "op": "add", "args": [{ "op": "mul", "args": [{ "op": "neg", "args": [{ "op": "input", "name": "a" }] }, { "op": "input", "name": "x" }] }, { "op": "reg", "name": "x_prev" }] }, { "op": "mul", "args": [{ "op": "input", "name": "a" }, { "op": "reg", "name": "y_prev" }] }] }
        }
      }
    }
  },
  "instances": {
    "ap_0": {
      "program": "_allpassStage",
      "inputs": {
        "x": { "op": "add", "args": [{ "op": "input", "name": "input" }, { "op": "mul", "args": [{ "op": "input", "name": "feedback" }, { "op": "reg", "name": "fb" }] }] },
        "a": { "op": "add", "args": [0.6, { "op": "mul", "args": [0.35, { "op": "sin", "args": [{ "op": "mul", "args": [6.283185307179586, { "op": "div", "args": [{ "op": "mul", "args": [{ "op": "sample_index" }, { "op": "input", "name": "lfo_speed" }] }, { "op": "sample_rate" }] }] }] }] }] }
      }
    },
    "ap_1": {
      "program": "_allpassStage",
      "inputs": {
        "x": { "op": "nested_out", "ref": "ap_0", "output": "y" },
        "a": { "op": "add", "args": [0.6, { "op": "mul", "args": [0.35, { "op": "sin", "args": [{ "op": "mul", "args": [6.283185307179586, { "op": "div", "args": [{ "op": "mul", "args": [{ "op": "sample_index" }, { "op": "input", "name": "lfo_speed" }] }, { "op": "sample_rate" }] }] }] }] }] }
      }
    },
    "ap_2": {
      "program": "_allpassStage",
      "inputs": {
        "x": { "op": "nested_out", "ref": "ap_1", "output": "y" },
        "a": { "op": "add", "args": [0.6, { "op": "mul", "args": [0.35, { "op": "sin", "args": [{ "op": "mul", "args": [6.283185307179586, { "op": "div", "args": [{ "op": "mul", "args": [{ "op": "sample_index" }, { "op": "input", "name": "lfo_speed" }] }, { "op": "sample_rate" }] }] }] }] }] }
      }
    },
    "ap_3": {
      "program": "_allpassStage",
      "inputs": {
        "x": { "op": "nested_out", "ref": "ap_2", "output": "y" },
        "a": { "op": "add", "args": [0.6, { "op": "mul", "args": [0.35, { "op": "sin", "args": [{ "op": "mul", "args": [6.283185307179586, { "op": "div", "args": [{ "op": "mul", "args": [{ "op": "sample_index" }, { "op": "input", "name": "lfo_speed" }] }, { "op": "sample_rate" }] }] }] }] }] }
      }
    }
  },
  "process": {
    "outputs": {
      "output": { "op": "add", "args": [{ "op": "mul", "args": [0.5, { "op": "input", "name": "input" }] }, { "op": "mul", "args": [0.5, { "op": "nested_out", "ref": "ap_3", "output": "y" }] }] },
      "lfo": { "op": "sin", "args": [{ "op": "mul", "args": [6.283185307179586, { "op": "div", "args": [{ "op": "mul", "args": [{ "op": "sample_index" }, { "op": "input", "name": "lfo_speed" }] }, { "op": "sample_rate" }] }] }] }
    },
    "next_regs": {
      "fb": { "op": "nested_out", "ref": "ap_3", "output": "y" }
    }
  }
