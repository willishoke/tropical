{
  "schema": "tropical_program_1",
  "name": "VCO",
  "inputs": [
    { "name": "freq", "type": "float" },
    { "name": "fm", "type": "float" },
    { "name": "fm_index", "type": "float" }
  ],
  "outputs": [
    { "name": "saw", "type": "float" },
    { "name": "tri", "type": "float" },
    { "name": "sin", "type": "float" },
    { "name": "sqr", "type": "float" }
  ],
  "regs": { "phase": 0.0, "tri_state": 0.0 },
  "input_defaults": { "freq": 100.0, "fm": 0.0, "fm_index": 5.0 },
  "programs": {
    "_wrap01": {
      "schema": "tropical_program_1",
      "name": "_wrap01",
      "inputs": ["x"],
      "outputs": ["value"],
      "process": {
        "outputs": {
          "value": { "op": "mod", "args": [
            { "op": "add", "args": [
              { "op": "mod", "args": [{ "op": "input", "name": "x" }, 1.0] },
              1.0
            ]},
            1.0
          ]}
        }
      }
    },
    "_polyBlep": {
      "schema": "tropical_program_1",
      "name": "_polyBlep",
      "inputs": ["t", "dt"],
      "outputs": ["value"],
      "process": {
        "outputs": {
          "value": { "op": "mul", "args": [
            { "op": "mul", "args": [
              { "op": "gt", "args": [{ "op": "input", "name": "dt" }, 0.0] },
              { "op": "lt", "args": [{ "op": "input", "name": "dt" }, 1.0] }
            ]},
            { "op": "add", "args": [
              { "op": "mul", "args": [
                { "op": "lt", "args": [{ "op": "input", "name": "t" }, { "op": "input", "name": "dt" }] },
                { "op": "sub", "args": [
                  { "op": "sub", "args": [
                    { "op": "add", "args": [
                      { "op": "div", "args": [{ "op": "input", "name": "t" }, { "op": "input", "name": "dt" }] },
                      { "op": "div", "args": [{ "op": "input", "name": "t" }, { "op": "input", "name": "dt" }] }
                    ]},
                    { "op": "mul", "args": [
                      { "op": "div", "args": [{ "op": "input", "name": "t" }, { "op": "input", "name": "dt" }] },
                      { "op": "div", "args": [{ "op": "input", "name": "t" }, { "op": "input", "name": "dt" }] }
                    ]}
                  ]},
                  1.0
                ]}
              ]},
              { "op": "mul", "args": [
                { "op": "mul", "args": [
                  { "op": "gte", "args": [{ "op": "input", "name": "t" }, { "op": "input", "name": "dt" }] },
                  { "op": "gt", "args": [
                    { "op": "input", "name": "t" },
                    { "op": "sub", "args": [1.0, { "op": "input", "name": "dt" }] }
                  ]}
                ]},
                { "op": "add", "args": [
                  { "op": "add", "args": [
                    { "op": "mul", "args": [
                      { "op": "div", "args": [
                        { "op": "sub", "args": [{ "op": "input", "name": "t" }, 1.0] },
                        { "op": "input", "name": "dt" }
                      ]},
                      { "op": "div", "args": [
                        { "op": "sub", "args": [{ "op": "input", "name": "t" }, 1.0] },
                        { "op": "input", "name": "dt" }
                      ]}
                    ]},
                    { "op": "mul", "args": [
                      2.0,
                      { "op": "div", "args": [
                        { "op": "sub", "args": [{ "op": "input", "name": "t" }, 1.0] },
                        { "op": "input", "name": "dt" }
                      ]}
                    ]}
                  ]},
                  1.0
                ]}
              ]}
            ]}
          ]}
        }
      }
    }
  },
  "instances": {
    "phase_wrap": {
      "program": "_wrap01",
      "inputs": {
        "x": { "op": "add", "args": [
          { "op": "reg", "name": "phase" },
          { "op": "div", "args": [
            { "op": "mul", "args": [
              { "op": "input", "name": "freq" },
              { "op": "pow", "args": [
                2.0,
                { "op": "div", "args": [
                  { "op": "mul", "args": [{ "op": "input", "name": "fm_index" }, { "op": "input", "name": "fm" }] },
                  5.0
                ]}
              ]}
            ]},
            { "op": "sample_rate" }
          ]}
        ]}
      }
    },
    "blep_saw": {
      "program": "_polyBlep",
      "inputs": {
        "t": { "op": "nested_out", "ref": "phase_wrap", "output": 0 },
        "dt": { "op": "clamp", "args": [
          { "op": "div", "args": [
            { "op": "abs", "args": [
              { "op": "mul", "args": [
                { "op": "input", "name": "freq" },
                { "op": "pow", "args": [
                  2.0,
                  { "op": "div", "args": [
                    { "op": "mul", "args": [{ "op": "input", "name": "fm_index" }, { "op": "input", "name": "fm" }] },
                    5.0
                  ]}
                ]}
              ]}
            ]},
            { "op": "sample_rate" }
          ]},
          0.0, 0.5
        ]}
      }
    },
    "blep_sqr1": {
      "program": "_polyBlep",
      "inputs": {
        "t": { "op": "nested_out", "ref": "phase_wrap", "output": 0 },
        "dt": { "op": "clamp", "args": [
          { "op": "div", "args": [
            { "op": "abs", "args": [
              { "op": "mul", "args": [
                { "op": "input", "name": "freq" },
                { "op": "pow", "args": [
                  2.0,
                  { "op": "div", "args": [
                    { "op": "mul", "args": [{ "op": "input", "name": "fm_index" }, { "op": "input", "name": "fm" }] },
                    5.0
                  ]}
                ]}
              ]}
            ]},
            { "op": "sample_rate" }
          ]},
          0.0, 0.5
        ]}
      }
    },
    "sqr_phase_wrap": {
      "program": "_wrap01",
      "inputs": {
        "x": { "op": "add", "args": [
          { "op": "nested_out", "ref": "phase_wrap", "output": 0 },
          0.5
        ]}
      }
    },
    "blep_sqr2": {
      "program": "_polyBlep",
      "inputs": {
        "t": { "op": "nested_out", "ref": "sqr_phase_wrap", "output": 0 },
        "dt": { "op": "clamp", "args": [
          { "op": "div", "args": [
            { "op": "abs", "args": [
              { "op": "mul", "args": [
                { "op": "input", "name": "freq" },
                { "op": "pow", "args": [
                  2.0,
                  { "op": "div", "args": [
                    { "op": "mul", "args": [{ "op": "input", "name": "fm_index" }, { "op": "input", "name": "fm" }] },
                    5.0
                  ]}
                ]}
              ]}
            ]},
            { "op": "sample_rate" }
          ]},
          0.0, 0.5
        ]}
      }
    }
  },
  "process": {
    "outputs": {
      "saw": { "op": "mul", "args": [
        5.0,
        { "op": "sub", "args": [
          { "op": "sub", "args": [
            { "op": "mul", "args": [2.0, { "op": "nested_out", "ref": "phase_wrap", "output": 0 }] },
            1.0
          ]},
          { "op": "nested_out", "ref": "blep_saw", "output": 0 }
        ]}
      ]},
      "sin": { "op": "mul", "args": [
        5.0,
        { "op": "sin", "args": [
          { "op": "mul", "args": [6.283185307179586, { "op": "nested_out", "ref": "phase_wrap", "output": 0 }] }
        ]}
      ]},
      "sqr": { "op": "mul", "args": [
        5.0,
        { "op": "sub", "args": [
          { "op": "add", "args": [
            { "op": "sub", "args": [
              1.0,
              { "op": "mul", "args": [2.0, { "op": "gte", "args": [{ "op": "nested_out", "ref": "phase_wrap", "output": 0 }, 0.5] }] }
            ]},
            { "op": "nested_out", "ref": "blep_sqr1", "output": 0 }
          ]},
          { "op": "nested_out", "ref": "blep_sqr2", "output": 0 }
        ]}
      ]},
      "tri": { "op": "mul", "args": [
        5.0,
        { "op": "clamp", "args": [
          { "op": "add", "args": [
            { "op": "reg", "name": "tri_state" },
            { "op": "mul", "args": [
              { "op": "mul", "args": [
                { "op": "sub", "args": [
                  { "op": "add", "args": [
                    { "op": "sub", "args": [
                      1.0,
                      { "op": "mul", "args": [2.0, { "op": "gte", "args": [{ "op": "nested_out", "ref": "phase_wrap", "output": 0 }, 0.5] }] }
                    ]},
                    { "op": "nested_out", "ref": "blep_sqr1", "output": 0 }
                  ]},
                  { "op": "nested_out", "ref": "blep_sqr2", "output": 0 }
                ]},
                { "op": "clamp", "args": [
                  { "op": "div", "args": [
                    { "op": "abs", "args": [
                      { "op": "mul", "args": [
                        { "op": "input", "name": "freq" },
                        { "op": "pow", "args": [
                          2.0,
                          { "op": "div", "args": [
                            { "op": "mul", "args": [{ "op": "input", "name": "fm_index" }, { "op": "input", "name": "fm" }] },
                            5.0
                          ]}
                        ]}
                      ]}
                    ]},
                    { "op": "sample_rate" }
                  ]},
                  0.0, 0.5
                ]}
              ]},
              4.0
            ]}
          ]},
          -1.0, 1.0
        ]}
      ]}
    },
    "next_regs": {
      "phase": { "op": "nested_out", "ref": "phase_wrap", "output": 0 },
      "tri_state": { "op": "clamp", "args": [
        { "op": "add", "args": [
          { "op": "reg", "name": "tri_state" },
          { "op": "mul", "args": [
            { "op": "mul", "args": [
              { "op": "sub", "args": [
                { "op": "add", "args": [
                  { "op": "sub", "args": [
                    1.0,
                    { "op": "mul", "args": [2.0, { "op": "gte", "args": [{ "op": "nested_out", "ref": "phase_wrap", "output": 0 }, 0.5] }] }
                  ]},
                  { "op": "nested_out", "ref": "blep_sqr1", "output": 0 }
                ]},
                { "op": "nested_out", "ref": "blep_sqr2", "output": 0 }
              ]},
              { "op": "clamp", "args": [
                { "op": "div", "args": [
                  { "op": "abs", "args": [
                    { "op": "mul", "args": [
                      { "op": "input", "name": "freq" },
                      { "op": "pow", "args": [
                        2.0,
                        { "op": "div", "args": [
                          { "op": "mul", "args": [{ "op": "input", "name": "fm_index" }, { "op": "input", "name": "fm" }] },
                          5.0
                        ]}
                      ]}
                    ]}
                  ]},
                  { "op": "sample_rate" }
                ]},
                0.0, 0.5
              ]}
            ]},
            4.0
          ]}
        ]},
        -1.0, 1.0
      ]}
    }
  }
}
